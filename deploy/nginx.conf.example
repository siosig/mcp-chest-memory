# WAN deployment: nginx terminates TLS and proxies to the Docker backend.
#
# The backend's own bearer-token check stays active behind the proxy, so a
# missing/wrong CHEST_API_TOKEN is rejected even if nginx is misconfigured.
# nginx passes the Authorization header through by default; the explicit
# proxy_set_header below just makes that visible.
#
# Optional hardening: uncomment the auth_basic lines to require an additional
# HTTP Basic credential at the edge (defense in depth).

server {
    listen 443 ssl;
    http2 on;
    server_name chest.example.com;

    ssl_certificate     /etc/letsencrypt/live/chest.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/chest.example.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;

    # Security headers
    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;
    add_header Referrer-Policy no-referrer always;

    # Tool payloads are small; match the backend's 1MB body limit.
    client_max_body_size 1m;

    location / {
        # auth_basic           "chest";
        # auth_basic_user_file /etc/nginx/chest.htpasswd;

        proxy_pass http://127.0.0.1:8765;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Authorization $http_authorization;
        proxy_read_timeout 60s;
    }
}

server {
    listen 80;
    server_name chest.example.com;
    return 301 https://$host$request_uri;
}

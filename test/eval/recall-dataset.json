    {
      "slug": "env-fts-tokenize",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "implementation",
      "content": "CHEST_FTS_TOKENIZE env var controls whether Sudachi tokenization is applied on write. Default true. Set false to disable."
    },
    {
      "slug": "chest-index-migrate",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "implementation",
      "content": "chest-index migrate: backfills content_tokenized for all existing memories, rebuilds FTS index after schema migration"
    },
    {
      "slug": "database-url-config",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "implementation",
      "content": "DATABASE_URL points to SQLite file. CHEST_DB_PATH is the same path without file: prefix. Used by dbPath() utility."
    },
    {
      "slug": "activation-score",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "learning",
      "content": "activation score = importance * recency * access frequency, computed by ACT-R inspired formula, used for memory ranking"
    },
    {
      "slug": "momentum-score",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "learning",
      "content": "momentum score tracks entity activity level. refreshed on every remember/recall. used as a tiebreaker in recall ranking."
    },
    {
      "slug": "protect-realize",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "realize",
      "content": "realize layer memories are auto-protected (protected=1). Never forgotten by decay sweep. Use for critical pitfalls."
    },
    {
      "slug": "nodejs-version",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "implementation",
      "content": "Node.js v24 required. Uses DatabaseSync from node:sqlite (added in v22.5). ESM-only package."
    },
    {
      "slug": "pnpm-workspace",
      "entity_name": "dainipc-server",
      "entity_kind": "project",
      "layer": "implementation",
      "content": "pnpm workspace root ~/workspace. Filter: --filter mcp-chest-memory. Never use npm install."
    },
    {
      "slug": "cos-similarity",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "learning",
      "content": "cosine similarity computed as dot product of L2-normalized vectors. Stored as FLOAT in memories.embedding (JSON array)."
    },
    {
      "slug": "fts5-bm25",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "learning",
      "content": "FTS5 bm25() returns negative values: smaller = better relevance. Used ascending ORDER BY in recall query."
    },
    {
      "slug": "typecheck-tsc",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "implementation",
      "content": "pnpm run typecheck runs tsc --noEmit. Must pass before PR. TypeScript 6 strict mode."
    },
    {
      "slug": "linksee-rebrand",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "realize",
      "content": "CRITICAL: the package was renamed from linksee to chest. Never include linksee in commits, code, or docs. Run check-rebrand before commit."
    },
    {
      "slug": "embedding-status-pending",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "implementation",
      "content": "embedding_status = pending on insert. chest-index reembed backfills embeddings async. CHEST_SYNC_EMBED=1 embeds synchronously on write."
    },
    {
      "slug": "supersession-manual",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "learning",
      "content": "supersedes field in chest_remember: explicitly archive older memories. Protected or goal layer memories cannot be superseded."
    },
    {
      "slug": "chest-data-dir",
      "entity_name": "mcp-chest-memory",
      "entity_kind": "project",
      "layer": "implementation",
      "content": "CHEST_DATA_DIR default is ~/.local/share/chest-memory. chestRootDir() = dirname(dbPath()). model cache under chestRootDir()/models."
    }
